# Convex deployment URL (set by `npx convex dev` in .env.local for local dev)
PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# ---- Convex deployment env vars (set with `npx convex env set NAME value`) ----
# ADMIN_PASSWORD=            admin panel login password
# GITHUB_DEPLOY_TOKEN=       PAT with repo dispatch rights on GITHUB_REPO
# GITHUB_REPO=chrisyerga/vortyx
# FORGE_API_KEY=             forge_... API key from forge.lindale.tech
# FORGE_API_URL=https://forge.lindale.tech
# FORGE_WEBHOOK_SECRET=      random string; authenticates forge callback webhooks
# FORGE_PROJECT_ID=          optional global fallback forge project id
# FORGE_FAKE_SUBMIT=true     dev only: skip real forge calls, fake task submission
