---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found — Vortyx" description="Page not found." noindex>
  <main class="mx-auto flex min-h-screen max-w-xl flex-col items-center justify-center gap-4 px-6 text-center">
    <p class="text-6xl font-bold text-(--site-accent)">404</p>
    <h1 class="text-2xl font-semibold">Page not found</h1>
    <p class="text-slate-600">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a href="https://vortyx.dev/" class="mt-2 rounded-lg bg-(--site-accent) px-5 py-2 font-medium text-white">
      Back to vortyx.dev
    </a>
  </main>
</BaseLayout>
