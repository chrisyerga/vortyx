---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEnabledSites } from "../lib/sitesData";

const sites = await getEnabledSites();
---

<BaseLayout
  title="Vortyx — A network of focused topic sites"
  description="Vortyx hosts a growing network of focused topic sites, each dedicated to doing one subject well."
  canonicalUrl="https://vortyx.dev/"
>
  <main class="mx-auto max-w-4xl px-6 py-20">
    <header class="mb-16 text-center">
      <p class="mb-3 text-5xl">🌀</p>
      <h1 class="text-4xl font-bold tracking-tight">Vortyx</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        A network of focused topic sites — each one dedicated to covering a
        single subject well, from pets to tech and beyond.
      </p>
    </header>

    <section aria-labelledby="sites-heading">
      <h2 id="sites-heading" class="mb-6 text-2xl font-semibold">Our sites</h2>
      {sites.length === 0 && (
        <p class="text-slate-500">New sites are launching soon.</p>
      )}
      <ul class="grid gap-6 sm:grid-cols-2">
        {sites.map((site) => (
          <li>
            <a
              href={`https://${site.key}.vortyx.dev/`}
              class="block h-full rounded-2xl border border-slate-200 p-6 transition hover:shadow-md"
              style={`--site-accent: ${site.theme.accentColor}`}
            >
              <p class="text-3xl">{site.theme.heroEmoji ?? "🌀"}</p>
              <h3 class="mt-3 text-lg font-semibold text-(--site-accent)">
                {site.name}
              </h3>
              <p class="mt-1 text-sm text-slate-600">{site.description}</p>
              <p class="mt-3 font-mono text-xs text-slate-400">
                {site.key}.vortyx.dev
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>
</BaseLayout>
